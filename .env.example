# ============================================================
# itbisa-shop-report-bot environment variables
# ============================================================
#
# Copy this file to .env for local development. In production
# (GitHub Actions), these are provided as repository secrets.
#
# IMPORTANT: Use the SAME Shopee partner key and TikTok app
# secret as the order bots — but the token files generated by
# scripts/bootstrap_*_tokens.py are INDEPENDENT. The report bot
# maintains its own token chain on its own bot-state branch so
# it does not collide with the order bots' token rotation.

# ---------- Shopee ----------
SHOPEE_PARTNER_ID=1234567
SHOPEE_PARTNER_KEY=your_partner_key_here
SHOPEE_SHOP_ID=987654321

# ---------- TikTok Shop ----------
TIKTOKSHOP_APP_KEY=your_app_key_here
TIKTOKSHOP_APP_SECRET=your_app_secret_here
TIKTOKSHOP_SHOP_ID=your_shop_id_here

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100123456789
