# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# IDE
.idea/
.vscode/
*.iml

# Environment / secrets — never commit
.env

# Runtime state — lives on bot-state branch, NOT main.
# Both directories are kept in the repo (with .gitkeep) so the
# bootstrap scripts can write into them locally.
data/*
!data/.gitkeep

# Output xlsx files — generated by the bot, committed to bot-state
# branch by the workflow. Never on main.
output/

# State JSON — likewise on bot-state only.
state/

# Local discovery dumps from scripts/dump_reason_codes.py
discovery_*.txt
discovery_*.json

# OS junk
.DS_Store
Thumbs.db
